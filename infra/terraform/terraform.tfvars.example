aws_region  = "us-east-1"
project_name = "cw3"

# After `terraform apply` on ECR + first docker push:
# backend_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/cw3-backend:latest"
backend_image = "REPLACE_WITH_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/cw3-backend:latest"

# Globally unique bucket name for the React build
frontend_bucket_name = "cw3-midterm-tracker-frontend-YOURNAME"

# Required for browser access from CloudFront (HTTPS): ACM cert in the same region as the ALB
# (eu-north-1 ALB → ACM cert in eu-north-1). Then use terraform output -raw api_base_url_https for VITE_API_BASE_URL.
# certificate_arn = "arn:aws:acm:eu-north-1:123456789012:certificate/..."
#
# Optional: custom API hostname (ACM name + DNS CNAME → ALB). If set, api_base_url_https uses this instead of ELB DNS.
# api_public_base_url = "https://api.midtermelectiontracker.com"

# Secrets Manager JSON secret name (must exist before apply; see infra/README.md §4)
# secrets_manager_secret_name = "cw3-secrets"

# Optional: override; otherwise Terraform sets CORS to the CloudFront HTTPS URL
# cors_allowed_origins = "https://d111111abcdef8.cloudfront.net"

# Optional: custom SPA hostname (browser URL). CloudFront requires an ACM cert in us-east-1 only (not eu-north-1).
# 1) Request ACM (us-east-1) for e.g. www.midtermelectiontracker.com, DNS-validate in Cloudflare
# 2) Set both lines below, then terraform apply
# 3) Cloudflare DNS: CNAME www -> <terraform output -raw cloudfront_domain_name> (DNS-only / grey cloud)
# frontend_domain_name             = "www.midtermelectiontracker.com"
# cloudfront_acm_certificate_arn    = "arn:aws:acm:us-east-1:123456789012:certificate/..."
