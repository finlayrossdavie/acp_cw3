# Copy to .env.production for local production builds (optional; CI uses GitHub secret VITE_API_BASE_URL).
# Use the HTTPS hostname on your ACM cert (often api.<your-domain>, CNAME → ALB), not the raw elb.amazonaws.com name.
# Production: https://api.midtermelectiontracker.com

VITE_API_BASE_URL=https://api.example.com
