# Copy to .env.production for local production builds (optional; CI uses GitHub secret VITE_API_BASE_URL).
# Set the value from Terraform: terraform output -raw api_base_url_https
# (requires certificate_arn set). CloudFront (HTTPS) cannot call an http:// API — mixed content.

VITE_API_BASE_URL=https://your-alb-dns.region.elb.amazonaws.com
